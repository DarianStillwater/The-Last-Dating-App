# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth (for "Continue with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
# Web client ID is required (used by Expo auth proxy and Supabase provider).
# iOS/Android client IDs are optional for dev but needed for standalone builds.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Note: AWS credentials for the verify-photo edge function are set as
# Supabase Edge Function secrets via the dashboard, not in this file.
# Required secrets: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION
