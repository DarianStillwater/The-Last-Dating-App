{
  "expo": {
    "name": "The Last Dating App",
    "slug": "last-dating-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "lastdatingapp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#40916C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lastdatingapp.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Take selfies for photo verification",
        "NSPhotoLibraryUsageDescription": "Choose photos for your profile",
        "NSLocationWhenInUseUsageDescription": "Find matches near you",
        "NSFaceIDUsageDescription": "Secure login with Face ID"
      }
    },
    "android": {
      "package": "com.lastdatingapp.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#40916C"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b2a62317-dd4b-45ed-8a29-4c97844fefdd"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      "expo-notifications",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "b2a62317-dd4b-45ed-8a29-4c97844fefdd"
      }
    },
    "owner": "rogerooni"
  }
}
